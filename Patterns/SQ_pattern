using System;
namespace pattern{
    class SQ_Pattern{
        public static void Main(string[] args){
            Console.WriteLine("The number of grid is : ");
            int n = Convert.ToInt32(Console.ReadLine());
            for (int i=1;i<=n;i++){
                for(int j=1;j<=n;j++){
                    Console.Write(" * ");
                }
                Console.WriteLine();
            }
        }
    }
}
